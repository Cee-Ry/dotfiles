# .bash_aliases

# Multi way to use nvim
alias nano='nvim'
alias vi='nvim'
alias vim='nvim'

# Compiling
alias CCPP='g++ *.cpp -o main && clear && ./main'

# Shortcuts commnad
alias push='git push -u origin main'
alias lsa='ls -ahlp'
alias ls='ls -ap1'

# Application
alias gdm-settings='flatpak run io.github.realmazharhussain.GdmSettings'
